generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String
  emailVerified DateTime?
  avatar        String?
  phone         String?
  country       String?
  tier          Tier          @default(FREE)
  kycStatus     KycStatus     @default(PENDING)
  kycVerifiedAt DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  wallets       Wallet[]
  transactions  Transaction[]
  investments   Investment[]
  sessions      Session[]
  notifications Notification[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String
  currency      String
  balance       Decimal  @default(0) @db.Decimal(20, 8)
  accountNumber String   @unique
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTx        Transaction[] @relation("SenderWallet")
  receivedTx    Transaction[] @relation("ReceiverWallet")

  @@unique([userId, currency])
  @@map("wallets")
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  type             TransactionType
  status           TransactionStatus @default(PENDING)
  amount           Decimal           @db.Decimal(20, 8)
  currency         String
  toAmount         Decimal?          @db.Decimal(20, 8)
  toCurrency       String?
  exchangeRate     Decimal?          @db.Decimal(20, 8)
  fromWalletId     String?
  toWalletId       String?
  recipientName    String?
  recipientAccount String?
  recipientBank    String?
  fee              Decimal           @default(0) @db.Decimal(20, 8)
  feeCurrency      String?
  note             String?
  reference        String            @unique @default(cuid())
  failureReason    String?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  fromWallet       Wallet?           @relation("SenderWallet", fields: [fromWalletId], references: [id])
  toWallet         Wallet?           @relation("ReceiverWallet", fields: [toWalletId], references: [id])

  @@map("transactions")
}

model InvestmentPlan {
  id          String      @id @default(cuid())
  name        String
  currency    String
  roi         Decimal     @db.Decimal(5, 2)
  duration    Int
  minAmount   Decimal     @db.Decimal(20, 8)
  maxAmount   Decimal?    @db.Decimal(20, 8)
  risk        RiskLevel
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  investments Investment[]

  @@map("investment_plans")
}

model Investment {
  id              String           @id @default(cuid())
  userId          String
  planId          String
  currency        String
  amount          Decimal          @db.Decimal(20, 8)
  projectedReturn Decimal          @db.Decimal(20, 8)
  actualReturn    Decimal?         @db.Decimal(20, 8)
  status          InvestmentStatus @default(ACTIVE)
  startDate       DateTime         @default(now())
  maturityDate    DateTime
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  plan            InvestmentPlan   @relation(fields: [planId], references: [id])

  @@map("investments")
}

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String
  target    String
  rate      Decimal  @db.Decimal(20, 8)
  source    String   @default("exchangerate-api")
  fetchedAt DateTime @default(now())

  @@unique([base, target])
  @@map("exchange_rates")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum Tier {
  FREE
  PREMIUM
  BUSINESS
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  CONVERSION
  SEND
  RECEIVE
  INVESTMENT
  RETURN
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

enum InvestmentStatus {
  ACTIVE
  MATURED
  WITHDRAWN
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}